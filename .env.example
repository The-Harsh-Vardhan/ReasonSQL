# =====================================================================
# ReasonSQL 2.0 — Environment Configuration
# =====================================================================
#
# SECURITY WARNING:
# -----------------
# 1. NEVER commit this file with real API keys to Git!
# 2. The .gitignore is configured to ignore .env files.
# 3. Copy this file to `.env` before editing.
#
# SETUP INSTRUCTIONS:
# -------------------
# 1. Copy: cp .env.example .env
# 2. Fill in your API keys below
# 3. Run:  docker-compose up -d
# 4. API available at: http://localhost:8000
# Frontend: cd frontend-next && npm run dev
#
# GET API KEYS:
# -------------
# - Google Gemini: https://makersuite.google.com/app/apikey
# - Groq (free):   https://console.groq.com/keys
# - LangSmith:     https://smith.langchain.com (free account)
#
# =====================================================================

# =====================================================================
# LLM PROVIDERS
# =====================================================================

# Primary: Google Gemini (recommended — fast, 15 RPM free tier)
GEMINI_API_KEY=AIzaSy_PLACEHOLDER_KEY_HERE
# Optional: rotate through multiple keys (up to 9)
# GEMINI_API_KEY_1=AIzaSy_KEY_1
# GEMINI_API_KEY_2=AIzaSy_KEY_2

# Secondary Fallback: Groq (8B model only — see providers.py)
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Model selection (LangChain LiteLLM format)
LLM_MODEL=gemini/gemini-2.0-flash
GROQ_MODEL=groq/llama-3.1-8b-instant

# =====================================================================
# DATABASE — PostgreSQL (Docker)
# =====================================================================
# For Docker Compose: use service name as host
DATABASE_URL=postgresql://reasonsql:reasonsql@postgres:5432/reasonsql

# For local dev (without Docker): use localhost
# DATABASE_URL=postgresql://reasonsql:reasonsql@localhost:5432/reasonsql

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =====================================================================
# LANGSMITH — Observability & Tracing (Optional)
# =====================================================================
# Sign up for free at https://smith.langchain.com
# When enabled, ALL LangChain/LangGraph calls are traced with full
# inputs, outputs, latency, and token usage — great for debugging.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_langsmith_key_here
LANGCHAIN_PROJECT=ReasonSQL-2.0
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default

# =====================================================================
# vLLM — Self-Hosted Qwen (Optional, requires GPU)
# =====================================================================
# Run Qwen2.5-Coder-32B-Instruct locally via vLLM for zero API cost.
# Uncomment the vllm service in docker-compose.yml to use this.
# Without vLLM, Qwen falls back to the cloud API via LiteLLM.
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
ENABLE_VLLM_FALLBACK=false

# =====================================================================
# SYSTEM SETTINGS
# =====================================================================

# Rate limiting
MAX_LLM_CALLS_PER_QUERY=5

# Query safety
MAX_RESULT_ROWS=1000
DEFAULT_LIMIT=100

# Verbose logging (true/false)
VERBOSE=false

# CORS origins (comma-separated, * for all)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =====================================================================
# CACHING — Redis
# =====================================================================
# Optional: set REDIS_URL to enable Redis caching for LLM responses.
# Without it, falls back to in-memory cache (cleared on restart).
# REDIS_URL=redis://localhost:6379/0

# =====================================================================
# RETRIEVAL SETTINGS
# =====================================================================

# Embedding model for FAISS schema indexing
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cross-encoder reranking model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Hybrid retrieval: tables returned before reranking
HYBRID_RETRIEVAL_K=10

# Tables returned after cross-encoder reranking
RERANKER_TOP_N=5

# Only use RAG when schema has more than this many tables
RAG_THRESHOLD_TABLES=5
